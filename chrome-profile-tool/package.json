{
  "name": "chrome-profile-tool",
  "version": "1.0.0",
  "description": "Chrome Profile Management Tool for Etsy & TikTok Shop",
  "main": "dist/main/main/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p src/main/tsconfig.json && electron dist/main/main/main.js --inspect=5858",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build",
    "package": "npm run build && electron-builder --config.npmRebuild=false",
    "package:dir": "npm run build && electron-builder --dir --config.npmRebuild=false",
    "package:mac": "npm run build && electron-builder --mac --config.npmRebuild=false",
    "package:win": "npm run build && electron-builder --win --config.npmRebuild=false",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "chrome",
    "profile",
    "proxy",
    "anti-detect"
  ],
  "author": "JEG Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ngtranlam/JEG-IP-Profile-.git"
  },
  "devDependencies": {
    "@types/node": "^20.19.31",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "firebase-admin": "^13.6.1",
    "jest": "^29.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "firebase": "^12.9.0",
    "gologin": "^2.2.1",
    "lucide-react": "^0.300.0",
    "mysql2": "^3.16.3",
    "node-fetch": "^3.3.2",
    "playwright": "^1.57.0",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "postcss": "^8.4.32",
    "puppeteer": "^24.35.0",
    "puppeteer-core": "^24.35.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.7",
    "tailwindcss": "^3.3.6",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.jeg.chrome-profile-tool",
    "productName": "JEG Profile Manager",
    "afterPack": "./scripts/afterPack.js",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "node_modules/gologin/**/*",
      "node_modules/sqlite3/**/*",
      "node_modules/puppeteer/**/*",
      "node_modules/puppeteer-core/**/*",
      "node_modules/playwright/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JEG Profile Manager",
      "include": "installer.nsh"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "title": "JEG Profile Manager ${version}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
